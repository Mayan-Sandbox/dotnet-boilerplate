############################################################
## Build Folders (you can keep bin if you'd like to share compiled assets)
############################################################
[Bb]in/
[Oo]bj/
**/bin/
**/obj/

############################################################
## Rider specific settings
############################################################
.idea/
*.sln.iml

############################################################
## Visual Studio / .NET specific files
############################################################
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Auto-generated files (compiled outputs, caches, etc.)
*.log
*.cache
*.pdb
*.mdb

# Files generated by popular Visual Studio add-ons
*.ncb
*.sdf
*.opensdf
*.VC.db

############################################################
## Dotnet Core specific
############################################################
project.lock.json
project.fragment.lock.json
artifacts/

############################################################
## Additional files
############################################################
# Rider also uses these if present:
.vscode/
*.DotSettings.user
